@using System.Globalization
@inject LavadoService Svc
@inject CatalogoService Cat

<div class="panel">

    <!-- ============ NUEVO LAVADO ============ -->
    <section class="card">
        <h2>@(EsCamion ? "Nuevo lavado de camión" : "Nuevo lavado")</h2>
        <div class="form-grid">
            @if (EsCamion)
            {
                <label>
                    <span>Patente de unidad</span>
                    <ComboBuscador Items="PatentesOpciones" @bind-Value="form.Patente"
                                   Placeholder="Escribí o elegí la patente…" />
                </label>

                <label>
                    <span>Dársena</span>
                    <select @bind="form.Darsena">
                        <option value="">— elegir —</option>
                        @foreach (var d in DarsenasDisponibles)
                        {
                            <option value="@d">@d</option>
                        }
                    </select>
                </label>

                <label>
                    <span>Frigorífico</span>
                    <select @bind="form.Frigorifico">
                        <option value="">— elegir —</option>
                        @foreach (var f in frigorificos)
                        {
                            <option value="@f.Nombre">@f.Nombre</option>
                        }
                    </select>
                </label>

                <label>
                    <span>Tambores</span>
                    <ContadorCantidad @bind-Value="form.Tambores" />
                </label>

                <label>
                    <span>Pallets</span>
                    <ContadorCantidad @bind-Value="form.Pallets" />
                </label>
            }
            else
            {
                <label>
                    <span>Equipo / sector</span>
                    <input type="text" value="@Catalogo.SectorDe(Tipo)" disabled />
                </label>
            }

            <label>
                <span>Operarios <small class="muted">(turno @TurnoActualNombre)</small></span>
                <ComboBuscador Items="OperariosOpciones(form, disp)" LimpiarAlElegir="true"
                               OnElegido="n => AgregarOperario(form, n)"
                               Placeholder="Escribí y elegí un operario…" />
            </label>
        </div>

        @if (form.Operarios.Count > 0)
        {
            <div class="tags">
                @foreach (var n in form.Operarios)
                {
                    <span class="tag">@n <button type="button" @onclick="() => form.Operarios.Remove(n)">×</button></span>
                }
            </div>
        }

        <label class="full">
            <span>Incidencias generales</span>
            <textarea rows="2" @bind="form.Incidencias" placeholder="Opcional…"></textarea>
        </label>

        @if (!string.IsNullOrEmpty(error))
        {
            <p class="error">@error</p>
        }

        <button class="btn btn-primary btn-block" @onclick="Iniciar">
            @(EsCamion ? "Iniciar Atraco" : "Iniciar Lavado")
        </button>
    </section>

    <!-- ============ EN CURSO ============ -->
    <section class="card">
        <h2>En curso (@enCurso.Count)</h2>
        @if (enCurso.Count == 0)
        {
            <p class="muted">No hay lavados en curso.</p>
        }
        else
        {
            <div class="curso-grid">
                @foreach (var l in enCurso)
                {
                    <div class="curso">
                        <div class="curso-head">
                            <strong>@l.Patente</strong>
                            @if (EsCamion && !string.IsNullOrEmpty(l.Darsena))
                            {
                                <span class="badge">@l.Darsena</span>
                            }
                            <span class="estado estado-@l.Estado.Replace(" ", "")">@l.Estado</span>
                        </div>
                        <div class="curso-times">
                            @if (EsCamion)
                            {
                                <span>Atraco: <b>@FmtHora(l.InicioAtraco)</b></span>
                            }
                            <span>Inicio lavado: <b>@FmtHora(l.InicioLavado)</b></span>
                            <span>Fin lavado: <b>@FmtHora(l.FinLavado)</b></span>
                            @if (EsCamion)
                            {
                                <span>Desatraco: <b>@FmtHora(l.Desatraco)</b></span>
                            }
                        </div>
                        <div class="curso-ops">@(string.IsNullOrEmpty(l.OperariosTexto) ? "(sin operarios)" : l.OperariosTexto)</div>

                        @{ var next = LavadoService.ProximaEtapa(l); }
                        <div class="curso-actions">
                            @if (next is not null)
                            {
                                <button class="btn btn-estado-@l.Estado.Replace(" ", "")" @onclick="() => Avanzar(l.Id)">@next</button>
                            }
                            <button class="btn btn-ghost" @onclick="() => Editar(l)">Editar</button>
                            <button class="btn btn-danger" @onclick="() => Eliminar(l.Id)">✕</button>
                        </div>

                        @if (editId == l.Id)
                        {
                            <div class="editor">
                                @if (EsCamion)
                                {
                                    <label><span>Dársena</span>
                                        <select @bind="edit.Darsena">
                                            <option value="">—</option>
                                            @foreach (var d in DarsenasDisponiblesEdit)
                                            {
                                                <option value="@d">@d</option>
                                            }
                                        </select>
                                    </label>
                                }
                                <label><span>Frigorífico</span>
                                    <select @bind="edit.Frigorifico">
                                        <option value="">—</option>
                                        @foreach (var f in frigorificos)
                                        {
                                            <option value="@f.Nombre">@f.Nombre</option>
                                        }
                                    </select>
                                </label>
                                <div class="mini">
                                    <label><span>Tambores</span><ContadorCantidad @bind-Value="edit.Tambores" /></label>
                                    <label><span>Pallets</span><ContadorCantidad @bind-Value="edit.Pallets" /></label>
                                </div>
                                <label><span>Operarios</span>
                                    <ComboBuscador Items="OperariosOpciones(edit, dispEdit)" LimpiarAlElegir="true"
                                                   OnElegido="n => AgregarOperario(edit, n)"
                                                   Placeholder="Escribí y elegí un operario…" />
                                </label>
                                @if (edit.Operarios.Count > 0)
                                {
                                    <div class="tags">
                                        @foreach (var n in edit.Operarios)
                                        {
                                            <span class="tag">@n <button type="button" @onclick="() => edit.Operarios.Remove(n)">×</button></span>
                                        }
                                    </div>
                                }
                                <textarea rows="2" @bind="edit.Incidencias" placeholder="Incidencias…"></textarea>
                                <div class="curso-actions">
                                    <button class="btn btn-primary" @onclick="GuardarEdicion">Guardar</button>
                                    <button class="btn btn-ghost" @onclick="() => editId = null">Cancelar</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </section>

</div>

@code {
    [Parameter, EditorRequired] public TipoLavado Tipo { get; set; }

    private bool EsCamion => Tipo == TipoLavado.Camion;

    private List<Lavado> enCurso = new();

    // Catálogos cargados desde la BD (solo activos).
    private List<Operario> operarios = new();
    private List<Patente> patentes = new();
    private List<Frigorifico> frigorificos = new();

    private FormModel form = new();
    private FormModel edit = new();
    private int? editId;
    private string? error;

    private Disponibilidad disp = new();      // para el formulario "nuevo"
    private Disponibilidad dispEdit = new();   // para el lavado en edición (excluye el propio)
    private int comboKey;                      // fuerza el reset visual del combo de operarios

    protected override void OnInitialized()
    {
        // En los circuitos que no son camión el sector es fijo.
        if (!EsCamion) form.Patente = Catalogo.SectorDe(Tipo);
    }

    protected override async Task OnParametersSetAsync() => await Recargar();

    private async Task Recargar()
    {
        operarios = await Cat.OperariosAsync(soloActivos: true);
        patentes = await Cat.PatentesAsync(soloActivos: true);
        frigorificos = await Cat.FrigorificosAsync(soloActivos: true);

        enCurso = await Svc.EnCursoAsync(Tipo);
        disp = await Svc.DisponibilidadAsync(Tipo);
    }

    // ---- Disponibilidad ----
    private IEnumerable<string> PatentesDisponibles =>
        patentes.Select(p => p.Codigo).Where(c => !disp.PatentesOcupadas.Contains(c));

    private IEnumerable<string> DarsenasDisponibles =>
        Catalogo.Darsenas.Where(d => !disp.DarsenasOcupadas.Contains(d));

    private IEnumerable<string> DarsenasDisponiblesEdit =>
        Catalogo.Darsenas.Where(d => !dispEdit.DarsenasOcupadas.Contains(d));

    // Turno actual según la hora del sistema (Mañana 06–18, Tarde/Noche 18–06).
    private bool EsTurnoMananaAhora => Turnos.EsManana(DateTime.Now);
    private string TurnoActualNombre => EsTurnoMananaAhora ? "Mañana" : "Tarde/Noche";

    // Un operario "entra" en el turno actual si su turno asignado coincide.
    // Sin turno asignado => no se valida (se permite).
    private bool OperarioEnTurno(Operario o)
        => string.IsNullOrEmpty(o.Turno)
           || string.Equals(o.Turno, Turnos.Mañana, StringComparison.OrdinalIgnoreCase) == EsTurnoMananaAhora;

    private IEnumerable<Operario> OperariosDisponibles(FormModel m, Disponibilidad d) =>
        operarios.Where(o => OperarioEnTurno(o)
            && !d.OperariosOcupados.Contains(o.NombreCompleto) && !m.Operarios.Contains(o.NombreCompleto));

    // Opciones para el dropdown propio (ComboBuscador).
    private IEnumerable<ComboBuscador.Opcion> PatentesOpciones =>
        PatentesDisponibles.Select(p => new ComboBuscador.Opcion(p));

    private IEnumerable<ComboBuscador.Opcion> OperariosOpciones(FormModel m, Disponibilidad d) =>
        OperariosDisponibles(m, d).Select(o => new ComboBuscador.Opcion(o.NombreCompleto, o.Tipo.ToString()));

    private void AgregarOperario(FormModel m, string? nombre)
    {
        // Solo agrega si lo tipeado/elegido coincide con un operario real del listado.
        var match = operarios.FirstOrDefault(o => o.Activo &&
            string.Equals(o.NombreCompleto, nombre?.Trim(), StringComparison.OrdinalIgnoreCase));
        if (match is not null)
        {
            if (!OperarioEnTurno(match))
                error = $"{match.NombreCompleto} es del turno {match.Turno}; ahora es turno {TurnoActualNombre}.";
            else if (!m.Operarios.Contains(match.NombreCompleto))
            {
                m.Operarios.Add(match.NombreCompleto);
                error = null;
            }
        }
        comboKey++; // recrea el input para que vuelva a quedar vacío
    }

    private async Task Iniciar()
    {
        error = null;

        // Validación de datos obligatorios.
        var faltan = new List<string>();
        if (string.IsNullOrWhiteSpace(form.Patente)) faltan.Add(EsCamion ? "Patente" : "Sector");
        if (EsCamion && string.IsNullOrWhiteSpace(form.Darsena)) faltan.Add("Dársena");
        if (EsCamion && string.IsNullOrWhiteSpace(form.Frigorifico)) faltan.Add("Frigorífico");
        if (form.Operarios.Count == 0) faltan.Add("Operarios");
        if (faltan.Count > 0)
        {
            error = "Faltan completar: " + string.Join(", ", faltan) + ".";
            return;
        }

        // La patente tipeada tiene que existir en el listado.
        if (EsCamion)
        {
            var pat = patentes.FirstOrDefault(p => string.Equals(p.Codigo, form.Patente.Trim(), StringComparison.OrdinalIgnoreCase));
            if (pat is null)
            {
                error = $"La patente «{form.Patente}» no está en el listado. Elegila de las sugerencias o cargala en Configuración.";
                return;
            }
            form.Patente = pat.Codigo; // normaliza a la versión del catálogo
        }

        // Inserción con revalidación server-side (anti doble-asignación).
        var res = await Svc.IniciarAsync(Tipo, form.ToDto());
        if (!res.Ok)
        {
            error = res.Error;
            await Recargar();
            return;
        }

        form = new();
        if (!EsCamion) form.Patente = Catalogo.SectorDe(Tipo);
        await Recargar();
    }

    private async Task Avanzar(int id)
    {
        await Svc.AvanzarAsync(id);
        await Recargar();
    }

    private async Task Editar(Lavado l)
    {
        editId = l.Id;
        edit = new FormModel
        {
            Darsena = l.Darsena,
            Frigorifico = l.Frigorifico,
            Tambores = l.Tambores,
            Pallets = l.Pallets,
            Incidencias = l.Incidencias,
            Operarios = l.Operarios.Select(o => o.Nombre).ToList(),
        };
        dispEdit = await Svc.DisponibilidadAsync(Tipo, excluirId: l.Id);
    }

    private async Task GuardarEdicion()
    {
        if (editId is int id)
        {
            await Svc.GuardarEdicionAsync(id, edit.ToDto());
            editId = null;
            await Recargar();
        }
    }

    private async Task Eliminar(int id)
    {
        await Svc.EliminarAsync(id);
        if (editId == id) editId = null;
        await Recargar();
    }

    // --- Formato ---
    private static readonly CultureInfo Es = CultureInfo.GetCultureInfo("es-AR");
    private static string FmtHora(DateTime? d) => d?.ToString("h:mm:ss tt", Es) ?? "--:--";
    private static string FmtDur(TimeSpan? t) => t.HasValue ? $"{(int)t.Value.TotalHours}:{t.Value.Minutes:00}:{t.Value.Seconds:00}" : "--";

    // Modelo de formulario (con operarios como lista mutable).
    private class FormModel
    {
        public string Patente { get; set; } = "";
        public string? Darsena { get; set; }
        public string? Frigorifico { get; set; }
        public int Tambores { get; set; }
        public int Pallets { get; set; }
        public string? Incidencias { get; set; }
        public List<string> Operarios { get; set; } = new();

        public NuevoLavado ToDto() => new()
        {
            Patente = Patente,
            Darsena = Darsena,
            Frigorifico = Frigorifico,
            Tambores = Tambores,
            Pallets = Pallets,
            Incidencias = Incidencias,
            Operarios = Operarios.ToList(),
        };
    }
}
