@page "/reportes"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.Globalization
@inject ReporteService Rep
@inject CatalogoService Cat
@inject IJSRuntime JS

<PageTitle>Reportes</PageTitle>

<header class="page-head">
    <h1>Reportes <span class="info" tabindex="0" data-tip="@TipGeneral">i</span></h1>
    <p>Métricas semanales por turno y exportación a Excel. Pasá el mouse por la <b>i</b> de cada reporte para ver qué calcula.</p>
</header>

<div class="panel">
    <section class="card">
        <div class="form-grid">
            <label>
                <span>Circuito</span>
                <select @bind="tipoSel" @bind:after="Cargar">
                    <option value="Camion">Camiones</option>
                    <option value="Hielo">Fábrica de Hielo</option>
                    <option value="Hiel">Hiel</option>
                    <option value="Varias">Varias</option>
                    <option value="Todos">Todos</option>
                </select>
            </label>
            <label>
                <span>Desde</span>
                <input type="date" @bind="desde" @bind:after="Cargar" />
            </label>
            <label>
                <span>Hasta</span>
                <input type="date" @bind="hasta" @bind:after="Cargar" />
            </label>
        </div>
        <div class="curso-actions">
            <button class="btn btn-ghost" @onclick="Limpiar">Limpiar filtros</button>
            <button class="btn btn-primary" @onclick="Exportar" disabled="@(lavados.Count == 0)">Exportar a Excel</button>
        </div>
        <p class="muted" style="margin-top:10px">@lavados.Count lavados finalizados en el rango seleccionado.</p>
    </section>

    @if (metricas.Count == 0)
    {
        <section class="card"><p class="muted">No hay datos para mostrar con los filtros actuales.</p></section>
    }
    else
    {
        @foreach (var t in metricas)
        {
            <section class="card">
                <h2>@(t.Turno == "Resumen" ? "Resumen (total)" : "Turno " + t.Turno) <span class="info" tabindex="0" data-tip="@TipMetricas">i</span></h2>
                <div class="tabla-scroll">
                    <table class="grilla">
                        <thead>
                            <tr>
                                <th>Semana</th>
                                <th>Lavados</th>
                                <th>Total hs</th>
                                <th>Prom. hs</th>
                                <th>Operarios</th>
                                <th>Prom. op.</th>
                                <th>% Var. hs</th>
                                <th>% Var. lavados</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in t.Semanas)
                            {
                                <tr>
                                    <td class="num">@s.Semana</td>
                                    <td class="num">@s.Lavados</td>
                                    <td class="num">@FmtDur(s.TotalHoras)</td>
                                    <td class="num">@FmtDur(s.PromedioHoras)</td>
                                    <td class="num">@s.TotalOperarios</td>
                                    <td class="num">@s.PromedioOperarios.ToString("0.0", Es)</td>
                                    <td class="num">@FmtVar(s.VarHoras)</td>
                                    <td class="num">@FmtVar(s.VarLavados)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        <section class="card">
            <h2>Horas por operario <span class="info" tabindex="0" data-tip="@TipHoras">i</span></h2>
            @if (horas.Filas.Count == 0)
            {
                <p class="muted">Sin operarios en el rango.</p>
            }
            else
            {
                <div class="tabla-scroll">
                    <table class="grilla">
                        <thead>
                            <tr>
                                <th>Turno</th>
                                <th>Operario</th>
                                <th>Tipo</th>
                                @foreach (var sem in horas.Semanas)
                                {
                                    <th>Sem @sem hs</th>
                                    <th>Sem @sem d</th>
                                }
                                <th>Días trab.</th>
                                <th>Total hs</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in horas.Filas)
                            {
                                <tr>
                                    <td>@f.Turno</td>
                                    <td>@f.Operario</td>
                                    <td>@f.Tipo</td>
                                    @foreach (var sem in horas.Semanas)
                                    {
                                        var hs = f.PorSemana.TryGetValue(sem, out var h) ? h : TimeSpan.Zero;
                                        var d = f.DiasPorSemana.TryGetValue(sem, out var dd) ? dd : 0;
                                        <td class="num">@FmtDur(hs)</td>
                                        <td class="num">@d</td>
                                    }
                                    <td class="num">@f.DiasTrabajados</td>
                                    <td class="num"><b>@FmtDur(f.Total)</b></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="card">
            <h2>Resumen por mes <span class="info" tabindex="0" data-tip="@TipResumenMes">i</span></h2>
            @if (resumenMes.Count == 0)
            {
                <p class="muted">Sin datos.</p>
            }
            else
            {
                <div class="tabla-scroll">
                    <table class="grilla">
                        <thead>
                            <tr>
                                <th>Mes</th><th>Operario</th><th>Lavados</th>
                                <th>Días trab.</th><th>Hs trabajadas</th><th>Prom. lavado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in resumenMes)
                            {
                                <tr>
                                    <td>@r.Mes</td>
                                    <td>@r.Operario</td>
                                    <td class="num">@r.Lavados</td>
                                    <td class="num">@r.DiasTrabajados</td>
                                    <td class="num">@FmtDur(r.Horas)</td>
                                    <td class="num">@FmtDur(r.Promedio)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

@code {
    private static readonly CultureInfo Es = CultureInfo.GetCultureInfo("es-AR");

    // Textos de ayuda (tooltips) de cada reporte.
    private const string TipGeneral =
        "Todos los reportes usan SOLO lavados finalizados, filtrados por circuito y rango de fechas.\n\n" +
        "• Tiempo total: Camión = Desatraco − Atraco; Hielo/Hiel/Varias = Fin − Inicio lavado.\n" +
        "• Turno: Mañana 06:00–18:59, Tarde el resto.\n" +
        "• A cada operario presente en un lavado se le imputan las horas TOTALES de ese lavado " +
        "(si 2 personas lavan un camión de 40 min, cada una suma 40).";

    private const string TipMetricas =
        "Métricas por semana (ISO). Hay un bloque por turno (Mañana / Tarde, según la hora del lavado: Mañana 06–18, Tarde 18–06) y un bloque «Resumen» que totaliza ambos.\n\n" +
        "• Lavados: cantidad de la semana.\n" +
        "• Total hs: suma de los tiempos; Prom. hs: ÷ Lavados.\n" +
        "• Operarios: suma de operarios usados; Prom. op.: ÷ Lavados.\n" +
        "• % Var.: variación vs la semana anterior (N−1): (N − N−1) ÷ N−1. Si no hay semana previa, «—».";

    private const string TipHoras =
        "Horas trabajadas por cada operario, por semana.\n\n" +
        "• Por cada semana hay dos columnas: «hs» (horas trabajadas) y «d» (días trabajados esa semana).\n" +
        "• Días trab.: total de días distintos en todo el rango.\n" +
        "• Total hs: suma de todas las semanas.";

    private const string TipResumenMes =
        "Una fila por operario y por mes (AAAA-MM).\n\n" +
        "• Lavados: total de lavados del operario en el mes.\n" +
        "• Días trab.: días distintos.\n" +
        "• Hs trabajadas: suma de los tiempos totales.\n" +
        "• Prom. lavado: Hs trabajadas ÷ Lavados.";

    private string tipoSel = "Camion";
    private DateOnly? desde;
    private DateOnly? hasta;

    private List<Lavado> lavados = new();
    private List<MetricasTurno> metricas = new();
    private HorasReporte horas = new(new(), new());
    private List<OperarioMesResumen> resumenMes = new();
    private Dictionary<string, string?> turnoOperarios = new();

    protected override async Task OnInitializedAsync() => await Cargar();

    private TipoLavado? TipoSeleccion() => tipoSel switch
    {
        "Camion" => TipoLavado.Camion,
        "Hielo" => TipoLavado.Hielo,
        "Hiel" => TipoLavado.Hiel,
        "Varias" => TipoLavado.Varias,
        _ => null,
    };

    private async Task Cargar()
    {
        // Mapa operario -> turno asignado (para agrupar "Horas por operario").
        turnoOperarios = new(StringComparer.OrdinalIgnoreCase);
        foreach (var o in await Cat.OperariosAsync())
            turnoOperarios[o.NombreCompleto] = o.Turno;

        lavados = await Rep.ObtenerAsync(TipoSeleccion(), desde, hasta);
        metricas = Rep.CalcularMetricas(lavados);
        horas = Rep.CalcularHorasPorOperario(lavados, turnoOperarios);
        resumenMes = Rep.ResumenPorMes(lavados);
    }

    private async Task Limpiar()
    {
        desde = null;
        hasta = null;
        await Cargar();
    }

    private async Task Exportar()
    {
        var bytes = Rep.GenerarExcel(lavados, metricas, TipoSeleccion(), turnoOperarios);
        var b64 = Convert.ToBase64String(bytes);
        var nombre = $"reporte-lavados-{DateTime.Now:yyyyMMdd-HHmm}.xlsx";
        await JS.InvokeVoidAsync("descargarArchivo", nombre, b64,
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private static string FmtDur(TimeSpan t) => $"{(int)t.TotalHours}:{t.Minutes:00}:{t.Seconds:00}";
    private static string FmtVar(double? v) => v.HasValue ? v.Value.ToString("P1", Es) : "—";
}
