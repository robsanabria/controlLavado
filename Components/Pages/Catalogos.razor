@page "/catalogos"
@rendermode InteractiveServer
@inject CatalogoService Cat
@inject ImportacionService Imp

<PageTitle>Configuración</PageTitle>

<header class="page-head">
    <h1>Configuración</h1>
    <p>Alta, baja y modificación de operarios, patentes y frigoríficos</p>
</header>

<div class="panel">

    <!-- ===== IMPORTAR FORMS ===== -->
    <section class="card">
        <h2>Importar respuestas del Forms</h2>
        <p class="muted">Lee la hoja «Respuestas de formulario 1» y agrega los lavados a la reportería. Omite los que ya existan (misma patente y hora de atraco).</p>
        <div class="form-grid">
            <label style="grid-column:1/-1"><span>Ruta del archivo (.xlsx) en el servidor</span>
                <input @bind="rutaImport" placeholder="C:\...\Registro de lavadero.xlsx" />
            </label>
        </div>
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="ImportarRuta" disabled="@importando">
                @(importando ? "Importando…" : "Importar desde ruta")
            </button>
            <label class="btn btn-ghost" style="cursor:pointer">
                Subir archivo…
                <InputFile OnChange="ImportarArchivo" accept=".xlsx" style="display:none" />
            </label>
        </div>
        @if (resultadoImport is not null)
        {
            <p class="@(resultadoOk ? "muted" : "error")" style="margin-top:10px">@resultadoImport</p>
        }
    </section>

    <!-- ===== IMPORTAR MAESTRO DE PATENTES ===== -->
    <section class="card">
        <h2>Importar maestro de patentes</h2>
        <p class="muted">Lee un Excel con columnas Dominio, Modelo, Marca y Tipo Unidad. Crea las patentes nuevas y actualiza modelo/marca/tipo de las existentes.</p>
        <div class="form-grid">
            <label style="grid-column:1/-1"><span>Ruta del archivo (.xlsx) en el servidor</span>
                <input @bind="rutaPatentes" placeholder="C:\...\Libro1.xlsx" />
            </label>
        </div>
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="ImportarPatentesRuta" disabled="@importandoPat">
                @(importandoPat ? "Importando…" : "Importar desde ruta")
            </button>
            <label class="btn btn-ghost" style="cursor:pointer">
                Subir archivo…
                <InputFile OnChange="ImportarPatentesArchivo" accept=".xlsx" style="display:none" />
            </label>
        </div>
        @if (resultadoPat is not null)
        {
            <p class="@(resultadoPatOk ? "muted" : "error")" style="margin-top:10px">@resultadoPat</p>
        }
    </section>

    <!-- ===== OPERARIOS ===== -->
    <section class="card">
        <h2>Operarios (@ops.Count)</h2>
        <div class="form-grid">
            <label><span>Apellido</span><input @bind="opEdit.Apellido" /></label>
            <label><span>Nombre</span><input @bind="opEdit.Nombre" /></label>
            <label><span>DNI</span><input @bind="opEdit.Dni" /></label>
            <label><span>Tipo</span>
                <select @bind="opEdit.Tipo">
                    <option value="Offal">Offal</option>
                    <option value="Contrato">Contrato</option>
                </select>
            </label>
        </div>
        @if (errorOp is not null) { <p class="error">@errorOp</p> }
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="GuardarOp">@(opEdit.Id == 0 ? "Agregar" : "Guardar cambios")</button>
            @if (opEdit.Id != 0) { <button class="btn btn-ghost" @onclick="() => opEdit = new()">Cancelar</button> }
        </div>
        <div class="tabla-scroll" style="margin-top:14px">
            <table class="grilla">
                <thead><tr><th>Apellido</th><th>Nombre</th><th>DNI</th><th>Tipo</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                    @foreach (var o in ops)
                    {
                        <tr style="@(o.Activo ? "" : "opacity:.5")">
                            <td>@o.Apellido</td><td>@o.Nombre</td><td>@o.Dni</td><td>@o.Tipo</td>
                            <td>@(o.Activo ? "Activo" : "Baja")</td>
                            <td class="acciones">
                                <button class="btn btn-ghost" @onclick="() => EditarOp(o)">Editar</button>
                                <button class="btn btn-ghost" @onclick="() => ToggleOp(o.Id)">@(o.Activo ? "Dar de baja" : "Activar")</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <!-- ===== PATENTES ===== -->
    <section class="card">
        <h2>Patentes (@pats.Count)</h2>
        <div class="form-grid">
            <label><span>Código</span><input @bind="patEdit.Codigo" placeholder="Ej: AC356EI" /></label>
            <label><span>Modelo</span><input @bind="patEdit.Modelo" /></label>
            <label><span>Marca</span><input @bind="patEdit.Marca" /></label>
            <label><span>Tipo Unidad</span><input @bind="patEdit.TipoUnidad" /></label>
        </div>
        @if (errorPat is not null) { <p class="error">@errorPat</p> }
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="GuardarPat">@(patEdit.Id == 0 ? "Agregar" : "Guardar cambios")</button>
            @if (patEdit.Id != 0) { <button class="btn btn-ghost" @onclick="() => patEdit = new()">Cancelar</button> }
        </div>
        <div class="tabla-scroll" style="margin-top:14px">
            <table class="grilla">
                <thead><tr><th>Código</th><th>Modelo</th><th>Marca</th><th>Tipo Unidad</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                    @foreach (var p in pats)
                    {
                        <tr style="@(p.Activo ? "" : "opacity:.5")">
                            <td>@p.Codigo</td><td>@p.Modelo</td><td>@p.Marca</td><td>@p.TipoUnidad</td>
                            <td>@(p.Activo ? "Activo" : "Baja")</td>
                            <td class="acciones">
                                <button class="btn btn-ghost" @onclick="() => patEdit = new Patente { Id = p.Id, Codigo = p.Codigo, Modelo = p.Modelo, Marca = p.Marca, TipoUnidad = p.TipoUnidad, Activo = p.Activo }">Editar</button>
                                <button class="btn btn-ghost" @onclick="() => TogglePat(p.Id)">@(p.Activo ? "Dar de baja" : "Activar")</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <!-- ===== FRIGORÍFICOS ===== -->
    <section class="card">
        <h2>Frigoríficos (@frigs.Count)</h2>
        <div class="form-grid">
            <label><span>Nombre</span><input @bind="frigEdit.Nombre" /></label>
        </div>
        @if (errorFrig is not null) { <p class="error">@errorFrig</p> }
        <div class="curso-actions">
            <button class="btn btn-primary" @onclick="GuardarFrig">@(frigEdit.Id == 0 ? "Agregar" : "Guardar cambios")</button>
            @if (frigEdit.Id != 0) { <button class="btn btn-ghost" @onclick="() => frigEdit = new()">Cancelar</button> }
        </div>
        <div class="tabla-scroll" style="margin-top:14px">
            <table class="grilla">
                <thead><tr><th>Nombre</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                    @foreach (var f in frigs)
                    {
                        <tr style="@(f.Activo ? "" : "opacity:.5")">
                            <td>@f.Nombre</td><td>@(f.Activo ? "Activo" : "Baja")</td>
                            <td class="acciones">
                                <button class="btn btn-ghost" @onclick="() => frigEdit = new Frigorifico { Id = f.Id, Nombre = f.Nombre, Activo = f.Activo }">Editar</button>
                                <button class="btn btn-ghost" @onclick="() => ToggleFrig(f.Id)">@(f.Activo ? "Dar de baja" : "Activar")</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private List<Operario> ops = new();
    private List<Patente> pats = new();
    private List<Frigorifico> frigs = new();

    private Operario opEdit = new();
    private Patente patEdit = new();
    private Frigorifico frigEdit = new();
    private string? errorOp, errorPat, errorFrig;

    // Importación
    private string rutaImport = @"C:\Users\roberto.sanabria\Downloads\Registro de lavadero.xlsx";
    private bool importando;
    private bool resultadoOk;
    private string? resultadoImport;

    private async Task ImportarRuta()
    {
        importando = true; resultadoImport = null;
        Mostrar(await Imp.ImportarDesdeArchivoAsync(rutaImport));
        importando = false;
    }

    private async Task ImportarArchivo(InputFileChangeEventArgs e)
    {
        importando = true; resultadoImport = null;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;
            Mostrar(await Imp.ImportarAsync(ms));
        }
        catch (Exception ex) { resultadoOk = false; resultadoImport = "Error: " + ex.Message; }
        importando = false;
    }

    private void Mostrar(ImportacionResultado res)
    {
        resultadoOk = res.Ok;
        resultadoImport = res.Ok
            ? $"Listo: {res.Importados} lavados importados, {res.Omitidos} omitidos por duplicado (de {res.FilasLeidas} filas). " +
              $"Catálogo: +{res.OperariosNuevos} operarios, +{res.PatentesNuevas} patentes."
            : "Error: " + res.Error;
    }

    // Importación del maestro de patentes
    private string rutaPatentes = @"C:\Users\roberto.sanabria\Downloads\Libro1.xlsx";
    private bool importandoPat;
    private bool resultadoPatOk;
    private string? resultadoPat;

    private async Task ImportarPatentesRuta()
    {
        importandoPat = true; resultadoPat = null;
        MostrarPat(await Imp.ImportarPatentesDesdeArchivoAsync(rutaPatentes));
        await Cargar();
        importandoPat = false;
    }

    private async Task ImportarPatentesArchivo(InputFileChangeEventArgs e)
    {
        importandoPat = true; resultadoPat = null;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;
            MostrarPat(await Imp.ImportarPatentesAsync(ms));
            await Cargar();
        }
        catch (Exception ex) { resultadoPatOk = false; resultadoPat = "Error: " + ex.Message; }
        importandoPat = false;
    }

    private void MostrarPat(ImportPatentesResultado res)
    {
        resultadoPatOk = res.Ok;
        resultadoPat = res.Ok
            ? $"Listo: {res.Nuevas} patentes nuevas, {res.Actualizadas} actualizadas (de {res.FilasLeidas} filas)."
            : "Error: " + res.Error;
    }

    protected override async Task OnInitializedAsync() => await Cargar();

    private async Task Cargar()
    {
        ops = await Cat.OperariosAsync();
        pats = await Cat.PatentesAsync();
        frigs = await Cat.FrigorificosAsync();
    }

    private void EditarOp(Operario o) =>
        opEdit = new Operario { Id = o.Id, Apellido = o.Apellido, Nombre = o.Nombre, Dni = o.Dni, Tipo = o.Tipo, Activo = o.Activo };

    private async Task GuardarOp()
    {
        errorOp = null;
        if (string.IsNullOrWhiteSpace(opEdit.Apellido) || string.IsNullOrWhiteSpace(opEdit.Nombre))
        {
            errorOp = "Completá apellido y nombre.";
            return;
        }
        await Cat.GuardarOperarioAsync(opEdit);
        opEdit = new();
        await Cargar();
    }

    private async Task ToggleOp(int id) { await Cat.ToggleOperarioAsync(id); await Cargar(); }

    private async Task GuardarPat()
    {
        errorPat = null;
        if (string.IsNullOrWhiteSpace(patEdit.Codigo)) { errorPat = "Ingresá un código."; return; }
        patEdit.Codigo = patEdit.Codigo.Trim().ToUpperInvariant();
        await Cat.GuardarPatenteAsync(patEdit);
        patEdit = new();
        await Cargar();
    }

    private async Task TogglePat(int id) { await Cat.TogglePatenteAsync(id); await Cargar(); }

    private async Task GuardarFrig()
    {
        errorFrig = null;
        if (string.IsNullOrWhiteSpace(frigEdit.Nombre)) { errorFrig = "Ingresá un nombre."; return; }
        await Cat.GuardarFrigorificoAsync(frigEdit);
        frigEdit = new();
        await Cargar();
    }

    private async Task ToggleFrig(int id) { await Cat.ToggleFrigorificoAsync(id); await Cargar(); }
}
